{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mnemosyne",
  "version": "0.1.0",
  "identifier": "com.mnemosyne.app",
  "build": {
    "beforeDevCommand": "node node_modules/vite/bin/vite.js --host 127.0.0.1 --port 1420",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node node_modules/typescript/bin/tsc --noEmit && node node_modules/vite/bin/vite.js build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mnemosyne",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 620
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
